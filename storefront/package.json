{
  "name": "acceferm-pro-storefront",
  "version": "0.1.0",
  "private": true,
  "description": "AcceFerm Pro — plateforme e-commerce fermetures automatiques pour pros & industries",
  "scripts": {
    "dev": "next dev --turbopack",
    "devsafe": "rm -rf .next && next dev",
    "build": "next build",
    "start": "next start",
    "lint": "biome check .",
    "format": "biome format --write .",
    "typecheck": "tsc --noEmit",
    "payload": "cross-env PAYLOAD_CONFIG_PATH=./payload.config.ts payload",
    "payload:seed": "tsx --tsconfig tsconfig.json seed/seed-pilots.ts",
    "payload:generate-types": "payload generate:types"
  },
  "dependencies": {
    "@getbrevo/brevo": "^2.2.0",
    "@payloadcms/db-postgres": "^3.0.0",
    "@payloadcms/next": "^3.0.0",
    "@payloadcms/richtext-lexical": "^3.0.0",
    "@react-pdf/renderer": "^4.1.0",
    "clsx": "^2.1.1",
    "graphql": "^16.13.2",
    "lucide-react": "^0.469.0",
    "motion": "^11.18.0",
    "next": "^15.2.0",
    "payload": "^3.0.0",
    "react": "^19.0.0",
    "react-dom": "^19.0.0",
    "sharp": "^0.33.5",
    "stripe": "^17.4.0",
    "tailwind-merge": "^2.6.0",
    "zod": "^3.25.76"
  },
  "devDependencies": {
    "@biomejs/biome": "^1.9.4",
    "@tailwindcss/postcss": "^4.0.0",
    "@types/node": "^22.10.0",
    "@types/react": "^19.0.0",
    "@types/react-dom": "^19.0.0",
    "cross-env": "^7.0.3",
    "postcss": "^8.4.49",
    "tailwindcss": "^4.0.0",
    "tsx": "^4.19.0",
    "typescript": "^5.7.0"
  },
  "engines": {
    "node": ">=20.0.0"
  }
}
