# ══════════════════════════════════════════════════════════════════════
# .env.example — AcceFerm Pro
# ══════════════════════════════════════════════════════════════════════
# Copier en `.env.local` et remplir les valeurs.
# JAMAIS commiter `.env.local`.
# Toutes les clés SECRETES doivent être configurées dans Vercel (env vars).
# ══════════════════════════════════════════════════════════════════════

# ─── Payload CMS ───
PAYLOAD_SECRET=<generer-avec-openssl-rand-hex-32>
PAYLOAD_PUBLIC_SERVER_URL=http://localhost:3000

# ─── Base de données (Postgres Supabase EU) ───
# Format : postgres://postgres.<project>:<password>@aws-0-eu-west-3.pooler.supabase.com:5432/postgres
DATABASE_URI=<postgres-url-supabase-eu-west-3>

# ─── Stripe (mode test en sprint 1, live en sprint 2) ───
STRIPE_SECRET_KEY=sk_test_xxx
STRIPE_PUBLISHABLE_KEY=pk_test_xxx
STRIPE_WEBHOOK_SECRET=whsec_xxx

# ─── Brevo (email transactional) ───
BREVO_API_KEY=xkeysib-xxx
BREVO_SENDER_EMAIL=noreply@acceferm.fr
BREVO_SENDER_NAME="AcceFerm Pro"

# ─── App ───
NEXT_PUBLIC_SITE_URL=http://localhost:3000
NEXT_PUBLIC_SITE_NAME="AcceFerm Pro"

# ─── Optionnel sprint 2+ ───
# ODOO_URL=https://ief-and-co.odoo.com
# ODOO_DB=ief-and-co
# ODOO_USERNAME=api@iefandco.com
# ODOO_API_KEY=xxx
# SENTRY_DSN=https://xxx@sentry.io/xxx
# UPSTASH_REDIS_REST_URL=https://xxx.upstash.io
# UPSTASH_REDIS_REST_TOKEN=xxx
